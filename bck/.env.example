APP_NAME=sistemaEpidemiologico API
ENVIRONMENT=local
DATABASE_URL=postgresql+psycopg://app:app@localhost:5432/sistema_epidemiologico
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
COOKIE_SECURE=false
COOKIE_DOMAIN=
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Account lockout after repeated failed logins.
MAX_FAILED_LOGINS=5
LOCKOUT_MINUTES=15

# Basic rate limiting on auth endpoints (in-memory; use Redis on AWS).
LOGIN_RATE_LIMIT=10
LOGIN_RATE_WINDOW_SECONDS=60
FORGOT_PASSWORD_RATE_LIMIT=3
FORGOT_PASSWORD_RATE_WINDOW_SECONDS=86400

# Password set/reset email links.
PASSWORD_TOKEN_TTL_HOURS=48
FRONTEND_URL=http://localhost:5173

# Bootstrap admin account (env vars keep historical MANAGER_* names; the
# seeded user is assigned the "admin" role).
AUTO_CREATE_MANAGER=true
MANAGER_EMAIL=manager@example.com
MANAGER_PASSWORD=ChangeMe123!

# Email delivery. Leave SMTP_HOST empty to log links to the console (local dev).
# AWS transition: set these (or wire SES) to send real password emails.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@sistema-epidemiologico.local
